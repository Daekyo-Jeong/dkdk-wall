# Optional. If unset, /admin reset is open on the local/internal network.
ADMIN_PIN=

# Optional. Defaults to 3000.
PORT=3000

# Dev mode only. Comma-separated IP/hostname list allowed to access the dev server.
# Example: ALLOWED_DEV_ORIGINS=192.168.1.179,192.168.1.200
ALLOWED_DEV_ORIGINS=192.168.1.179

# Optional. Set 1 to run the custom server on HTTPS.
# iOS motion sensors usually require HTTPS (except localhost).
USE_HTTPS=0

# Required when USE_HTTPS=1. Paths are resolved from project root.
# Example:
# SSL_KEY_PATH=certs/192.168.1.179-key.pem
# SSL_CERT_PATH=certs/192.168.1.179.pem
SSL_KEY_PATH=
SSL_CERT_PATH=
